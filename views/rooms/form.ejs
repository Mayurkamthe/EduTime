<%- include('../partials/layout-start') %>
<div class="d-flex align-items-center gap-2 mb-4">
  <a href="/rooms" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left"></i></a>
  <h5 class="section-title mb-0"><%= room ? 'Edit Room' : 'Add Room' %></h5>
</div>
<div class="page-card" style="max-width:500px">
  <form action="<%= action %>" method="POST">
    <div class="row g-3">
      <div class="col-md-6">
        <label class="form-label">Room Number *</label>
        <input type="text" name="roomNumber" class="form-control" value="<%= room ? room.roomNumber : '' %>" required placeholder="e.g. 101, Lab-A">
      </div>
      <div class="col-md-6">
        <label class="form-label">Type *</label>
        <select name="type" class="form-select" required>
          <option value="classroom" <%= room && room.type==='classroom' ? 'selected' : '' %>>Classroom</option>
          <option value="lab" <%= room && room.type==='lab' ? 'selected' : '' %>>Lab</option>
        </select>
      </div>
      <div class="col-md-4">
        <label class="form-label">Capacity *</label>
        <input type="number" name="capacity" class="form-control" value="<%= room ? room.capacity : 60 %>" min="1" required>
      </div>
      <div class="col-md-4">
        <label class="form-label">Floor</label>
        <input type="text" name="floor" class="form-control" value="<%= room ? room.floor||'' : '' %>" placeholder="e.g. Ground, 1st">
      </div>
      <div class="col-md-4">
        <label class="form-label">Building</label>
        <input type="text" name="building" class="form-control" value="<%= room ? room.building||'' : '' %>" placeholder="e.g. Main Block">
      </div>
    </div>
    <div class="divider"></div>
    <div class="d-flex gap-2">
      <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg me-1"></i> Save Room</button>
      <a href="/rooms" class="btn btn-outline-secondary">Cancel</a>
    </div>
  </form>
</div>
<%- include('../partials/layout-end') %>
