<%- include('../partials/layout-start') %>
<div class="d-flex align-items-center gap-2 mb-4">
  <a href="/professors" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left"></i></a>
  <h5 class="section-title mb-0"><%= professor ? 'Edit Professor' : 'Add Professor' %></h5>
</div>
<div class="page-card" style="max-width:700px">
  <form action="<%= action %>" method="POST">
    <div class="row g-3">
      <div class="col-md-6">
        <label class="form-label">Full Name *</label>
        <input type="text" name="name" class="form-control" value="<%= professor ? professor.name : '' %>" required placeholder="e.g. Dr. Priya Sharma">
      </div>
      <div class="col-md-6">
        <label class="form-label">Email *</label>
        <input type="email" name="email" class="form-control" value="<%= professor ? professor.email : '' %>" required>
      </div>
      <div class="col-md-4">
        <label class="form-label">Employee ID</label>
        <input type="text" name="employeeId" class="form-control" value="<%= professor ? professor.employeeId||'' : '' %>">
      </div>
      <div class="col-md-4">
        <label class="form-label">Department</label>
        <input type="text" name="department" class="form-control" value="<%= professor ? professor.department||'' : '' %>">
      </div>
      <div class="col-md-4">
        <label class="form-label">Max Lectures/Day</label>
        <input type="number" name="maxLecturesPerDay" class="form-control" value="<%= professor ? professor.maxLecturesPerDay : 4 %>" min="1" max="8">
      </div>
      <div class="col-12">
        <label class="form-label">Subjects Can Teach</label>
        <div class="row g-2">
          <% subjects.forEach(s => { %>
            <div class="col-md-4 col-6">
              <div class="form-check">
                <input class="form-check-input" type="checkbox" name="subjects" value="<%= s._id %>" id="subj_<%= s._id %>"
                  <%= professor && professor.subjects.some(ps => ps.toString()===s._id.toString()) ? 'checked' : '' %>>
                <label class="form-check-label" for="subj_<%= s._id %>">
                  <code><%= s.code %></code> <small class="text-muted"><%= s.name %></small>
                </label>
              </div>
            </div>
          <% }) %>
        </div>
      </div>
      <div class="col-12">
        <label class="form-label">Available Days</label>
        <div class="d-flex flex-wrap gap-2">
          <% days.forEach(d => { %>
            <div class="form-check form-check-inline">
              <input class="form-check-input" type="checkbox" name="availableDays" value="<%= d %>" id="day_<%= d %>"
                <%= !professor || professor.availability.days.includes(d) ? 'checked' : '' %>>
              <label class="form-check-label" for="day_<%= d %>"><%= d.substr(0,3) %></label>
            </div>
          <% }) %>
        </div>
      </div>
    </div>
    <div class="divider"></div>
    <div class="d-flex gap-2">
      <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg me-1"></i> Save Professor</button>
      <a href="/professors" class="btn btn-outline-secondary">Cancel</a>
    </div>
  </form>
</div>
<%- include('../partials/layout-end') %>
