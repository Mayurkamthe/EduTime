<%- include('../partials/layout-start') %>
<div class="d-flex justify-content-between align-items-center mb-4">
  <h5 class="section-title mb-0">Timetable Management</h5>
</div>

<!-- Generate Form -->
<div class="page-card mb-4">
  <h6 class="fw-bold mb-3"><i class="bi bi-lightning-charge text-warning me-1"></i> Generate New Timetable</h6>
  <form action="/timetable/generate" method="POST" class="row g-3 align-items-end">
    <div class="col-md-3">
      <label class="form-label">Class / Division *</label>
      <select name="classId" class="form-select" required>
        <option value="">Select Class</option>
        <% classes.forEach(c => { %>
          <option value="<%= c._id %>"><%= c.year %>-<%= c.division %> (<%= c.totalStudents %> students)</option>
        <% }) %>
      </select>
    </div>
    <div class="col-md-2">
      <label class="form-label">Semester *</label>
      <select name="semester" class="form-select" required>
        <% for(let i=1;i<=8;i++) { %><option value="<%= i %>">Sem <%= i %></option><% } %>
      </select>
    </div>
    <div class="col-md-2">
      <label class="form-label">Academic Year *</label>
      <input type="text" name="academicYear" class="form-control" value="2024-25" required>
    </div>
    <div class="col-md-2">
      <div class="form-check mt-2">
        <input class="form-check-input" type="checkbox" name="regenerate" value="true" id="regen">
        <label class="form-check-label" for="regen">Force Regenerate</label>
      </div>
    </div>
    <div class="col-md-3">
      <button type="submit" class="btn btn-primary w-100">
        <i class="bi bi-cpu me-1"></i> Generate Timetable
      </button>
    </div>
  </form>
</div>

<!-- Existing Timetables -->
<div class="page-card">
  <h6 class="fw-bold mb-3"><i class="bi bi-calendar-week me-1 text-primary"></i> Generated Timetables</h6>
  <% if (!timetables.length) { %>
    <div class="text-center py-5 text-muted">
      <i class="bi bi-calendar-x fs-1 d-block mb-2"></i>No timetables generated yet. Use the form above.
    </div>
  <% } else { %>
  <div class="table-responsive">
    <table class="table table-hover align-middle mb-0">
      <thead class="table-dark">
        <tr><th>Class</th><th>Year</th><th>Sem</th><th>Generated</th><th>Actions</th></tr>
      </thead>
      <tbody>
        <% timetables.forEach(tt => { %>
        <tr>
          <td class="fw-bold"><%= tt.class ? tt.class.year+'-'+tt.class.division : 'N/A' %></td>
          <td><%= tt.academicYear %></td>
          <td>Sem <%= tt.semester %></td>
          <td><%= tt.generatedAt ? new Date(tt.generatedAt).toLocaleDateString('en-IN') : '-' %></td>
          <td class="d-flex gap-1 flex-wrap">
            <a href="/timetable/class/<%= tt.class._id %>?semester=<%= tt.semester %>&year=<%= tt.academicYear %>" class="btn btn-outline-primary btn-sm">
              <i class="bi bi-eye me-1"></i>View
            </a>
            <a href="/export/pdf?classId=<%= tt.class._id %>" class="btn btn-outline-danger btn-sm" target="_blank">
              <i class="bi bi-file-pdf me-1"></i>PDF
            </a>
            <a href="/export/excel?classId=<%= tt.class._id %>" class="btn btn-outline-success btn-sm">
              <i class="bi bi-file-excel me-1"></i>Excel
            </a>
            <form action="/timetable/<%= tt._id %>?_method=DELETE" method="POST" class="d-inline">
              <button class="btn btn-outline-danger btn-sm confirm-delete"><i class="bi bi-trash"></i></button>
            </form>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
  <% } %>
</div>
<%- include('../partials/layout-end') %>
