<%- include('../partials/layout-start') %>
<div class="d-flex justify-content-between align-items-center mb-4">
  <h5 class="section-title mb-0">Faculty Timetables</h5>
</div>
<div class="page-card">
  <% if (!professors.length) { %>
    <div class="text-center py-5 text-muted"><i class="bi bi-person-badge fs-1 d-block mb-2"></i>No professors found.</div>
  <% } else { %>
  <div class="row g-3">
    <% professors.forEach(p => { %>
      <div class="col-md-3 col-sm-4 col-6">
        <a href="/timetable/professor/<%= p._id %>" class="text-decoration-none">
          <div class="p-3 border rounded text-center hover-card">
            <i class="bi bi-person-circle fs-2 text-primary d-block mb-2"></i>
            <div class="fw-semibold" style="font-size:13px"><%= p.name %></div>
            <small class="text-muted"><%= p.email %></small>
          </div>
        </a>
      </div>
    <% }) %>
  </div>
  <% } %>
</div>
<%- include('../partials/layout-end') %>
