<div class="sidebar d-flex flex-column" id="sidebar">
  <div class="sidebar-brand px-3 py-3 d-flex align-items-center gap-2 border-bottom border-secondary">
    <i class="bi bi-calendar2-week fs-4 text-primary"></i>
    <span class="fw-bold text-white fs-6">SPPU Timetable</span>
  </div>
  <nav class="flex-grow-1 py-2">
    <ul class="nav flex-column px-2">
      <li class="nav-item">
        <a href="/dashboard" class="nav-link sidebar-link <%= locals.activePage==='dashboard'?'active':'' %>">
          <i class="bi bi-speedometer2"></i><span>Dashboard</span>
        </a>
      </li>
      <li class="nav-item mt-1">
        <a href="/subjects" class="nav-link sidebar-link <%= locals.activePage==='subjects'?'active':'' %>">
          <i class="bi bi-book"></i><span>Subjects</span>
        </a>
      </li>
      <li class="nav-item mt-1">
        <a href="/professors" class="nav-link sidebar-link <%= locals.activePage==='professors'?'active':'' %>">
          <i class="bi bi-person-badge"></i><span>Professors</span>
        </a>
      </li>
      <li class="nav-item mt-1">
        <a href="/rooms" class="nav-link sidebar-link <%= locals.activePage==='rooms'?'active':'' %>">
          <i class="bi bi-building"></i><span>Rooms</span>
        </a>
      </li>
      <li class="nav-item mt-1">
        <a href="/classes" class="nav-link sidebar-link <%= locals.activePage==='classes'?'active':'' %>">
          <i class="bi bi-people"></i><span>Classes</span>
        </a>
      </li>
      <li class="nav-item mt-2 px-2">
        <small class="text-uppercase text-secondary" style="font-size:10px;letter-spacing:1px">Timetable</small>
      </li>
      <li class="nav-item mt-1">
        <a href="/timetable" class="nav-link sidebar-link <%= locals.activePage==='timetable'?'active':'' %>">
          <i class="bi bi-grid-3x3-gap"></i><span>Timetables</span>
        </a>
      </li>
      <li class="nav-item mt-1">
        <a href="/timetable/all-professors" class="nav-link sidebar-link <%= locals.activePage==='faculty-tt'?'active':'' %>">
          <i class="bi bi-person-lines-fill"></i><span>Faculty TT</span>
        </a>
      </li>
      <li class="nav-item mt-1">
        <a href="/timetable/all-rooms" class="nav-link sidebar-link <%= locals.activePage==='room-tt'?'active':'' %>">
          <i class="bi bi-door-open"></i><span>Room TT</span>
        </a>
      </li>
      <li class="nav-item mt-2 px-2">
        <small class="text-uppercase text-secondary" style="font-size:10px;letter-spacing:1px">Admin</small>
      </li>
      <li class="nav-item mt-1">
        <a href="/settings" class="nav-link sidebar-link <%= locals.activePage==='settings'?'active':'' %>">
          <i class="bi bi-gear"></i><span>Settings</span>
        </a>
      </li>
    </ul>
  </nav>
  <div class="sidebar-footer px-3 py-3 border-top border-secondary">
    <div class="d-flex align-items-center gap-2 text-light mb-2">
      <i class="bi bi-person-circle fs-5"></i>
      <div>
        <div class="fw-semibold" style="font-size:13px"><%= user.name %></div>
        <div style="font-size:11px;color:#aaa"><%= user.role.toUpperCase() %></div>
      </div>
    </div>
    <form action="/logout" method="POST">
      <button class="btn btn-sm btn-outline-danger w-100">
        <i class="bi bi-box-arrow-right"></i> Logout
      </button>
    </form>
  </div>
</div>
